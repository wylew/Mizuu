<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:liftOnScroll="true">

        <include layout="@layout/toolbar_layout" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Floating bottom controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Search Button - Standard 56dp size, fixed centering -->
        <com.google.android.material.button.MaterialButton
        app:iconGravity="textStart"
        app:iconPadding="0dp"
            android:id="@+id/search_button"
            style="?attr/materialIconButtonFilledTonalStyle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_search_white_24dp"
            android:gravity="center"
            android:elevation="8dp"
            app:backgroundTint="?attr/colorSecondaryContainer"
            app:iconTint="?attr/colorOnSecondaryContainer"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Floating Connected Button Group Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/toggle_card"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/menu_button"
            app:layout_constraintStart_toEndOf="@+id/search_button">

            <com.google.android.material.button.MaterialButtonToggleGroup
        app:iconGravity="textStart"
        app:iconPadding="0dp"
                android:id="@+id/library_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
        app:iconGravity="textStart"
        app:iconPadding="0dp"
                    android:id="@+id/btn_all"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_video_collection_white_24dp"
                    android:text="@string/all"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

                <com.google.android.material.button.MaterialButton
        app:iconGravity="textStart"
        app:iconPadding="0dp"
                    android:id="@+id/btn_movies"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_movie_white_24dp"
                    android:text="@string/chooserMovies"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

                <com.google.android.material.button.MaterialButton
        app:iconGravity="textStart"
        app:iconPadding="0dp"
                    android:id="@+id/btn_tv"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_tv_white_24dp"
                    android:text="@string/chooserTVShows"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    app:iconTint="?attr/colorOnSurface"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        </com.google.android.material.card.MaterialCardView>

        <!-- Menu Button (Standard 56dp size) - Fixed icon centering -->
        <com.google.android.material.button.MaterialButton
        app:iconGravity="textStart"
        app:iconPadding="0dp"
            android:id="@+id/menu_button"
            style="?attr/materialIconButtonFilledTonalStyle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_more_vert_white_24dp"
            android:gravity="center"
            android:elevation="8dp"
            app:backgroundTint="?attr/colorSurface"
            app:iconTint="?attr/colorOnSurface"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
