<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base theme for all Mizuu themes -->
    <style name="Mizuu.Theme.Base" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:listSelector">@drawable/list_selector</item>
        <item name="android:editTextStyle">@style/RobotoEditTextStyle</item>
        <item name="android:textViewStyle">@style/RobotoTextViewStyle</item>
        <item name="android:checkboxStyle">@style/CheckBoxAppTheme</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>

        <!-- M3 Expressive values -->
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Material3.TitleLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Material3.BodyMedium</item>

        <item name="toolbarStyle">@style/Mizuu.Toolbar</item>
    </style>

    <style name="Mizuu.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
    </style>

    <!-- Light Theme -->
    <style name="Mizuu.Theme.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:listSelector">@drawable/list_selector</item>
        <item name="android:editTextStyle">@style/RobotoEditTextStyle</item>
        <item name="android:textViewStyle">@style/RobotoTextViewStyle</item>
        <item name="android:checkboxStyle">@style/CheckBoxAppTheme</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>

        <!-- Material 3 Color Roles -->
        <item name="colorPrimary">#6750A4</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#EADDFF</item>
        <item name="colorOnPrimaryContainer">#21005D</item>
        <item name="colorSecondary">#625B71</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
        <item name="colorOnSecondaryContainer">#1D192B</item>
        <item name="colorTertiary">#7D5260</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#FFD8E4</item>
        <item name="colorOnTertiaryContainer">#31111D</item>
        <item name="colorSurface">#FFFBFE</item>
        <item name="colorOnSurface">#1C1B1F</item>
        <item name="colorSurfaceVariant">#E7E0EC</item>
        <item name="colorOnSurfaceVariant">#49454F</item>
        <item name="android:windowBackground">#FFFBFE</item>

        <item name="colorControlNormal">?attr/colorOnSurface</item>
        <item name="actionMenuTextColor">?attr/colorOnSurface</item>
    </style>

    <!-- Dark Theme -->
    <style name="Mizuu.Theme.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:listSelector">@drawable/list_selector</item>
        <item name="android:editTextStyle">@style/RobotoEditTextStyle</item>
        <item name="android:textViewStyle">@style/RobotoTextViewStyle</item>
        <item name="android:checkboxStyle">@style/CheckBoxAppTheme</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>

        <!-- Material 3 Color Roles -->
        <item name="colorPrimary">#D0BCFF</item>
        <item name="colorOnPrimary">#381E72</item>
        <item name="colorPrimaryContainer">#4F378B</item>
        <item name="colorOnPrimaryContainer">#EADDFF</item>
        <item name="colorSecondary">#CCC2DC</item>
        <item name="colorOnSecondary">#332D41</item>
        <item name="colorSecondaryContainer">#4A4458</item>
        <item name="colorOnSecondaryContainer">#E8DEF8</item>
        <item name="colorTertiary">#EFB8C8</item>
        <item name="colorOnTertiary">#492532</item>
        <item name="colorTertiaryContainer">#633B48</item>
        <item name="colorOnTertiaryContainer">#FFD8E4</item>
        <item name="colorSurface">#1C1B1F</item>
        <item name="colorOnSurface">#E6E1E5</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>
        <item name="android:windowBackground">#1C1B1F</item>

        <item name="colorControlNormal">?attr/colorOnSurface</item>
        <item name="actionMenuTextColor">?attr/colorOnSurface</item>
    </style>

    <!-- System Theme -->
    <style name="Mizuu.Theme.System" parent="Mizuu.Theme.Base" />

    <!-- Default Theme -->
    <style name="Mizuu.Theme" parent="Mizuu.Theme.Light" />

    <style name="Mizuu.Theme.Overview" parent="Mizuu.Theme">
        <item name="colorSurface">?android:attr/windowBackground</item>
    </style>

    <style name="RobotoTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="RobotoEditTextStyle" parent="android:Widget.EditText">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="CheckBoxAppTheme" parent="android:Widget.CompoundButton.CheckBox">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="Mizuu.Theme.Transparent.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Mizuu.Theme.NoBackground" parent="Mizuu.Theme">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Mizuu.Theme.Translucent.FullScreen" parent="Mizuu.Theme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Mizuu.Theme.Preference" parent="Mizuu.Theme">
        <item name="android:windowBackground">@drawable/bg</item>
    </style>

</resources>